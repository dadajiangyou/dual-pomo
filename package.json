{
  "name": "dual-pomo",
  "version": "1.0.0",
  "description": "双形态番茄计时器 - 桌面版",
  "main": "main.js",
  "author": "Dual-Pomo",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "electron-builder --win --mac --linux"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.dual-pomo.app",
    "productName": "Dual-Pomo",
    "copyright": "Copyright © 2026 Dual-Pomo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "pomodoro.html",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Dual-Pomo"
    },
    "publish": {
      "provider": "github",
      "owner": "wsxsx",
      "repo": "dual-pomo"
    }
  }
}
